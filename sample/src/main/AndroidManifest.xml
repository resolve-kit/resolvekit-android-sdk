<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".SampleApplication"
        android:label="ResolveKit Sample"
        android:theme="@style/Theme.Material3.Light.NoActionBar">

        <!-- Launcher — redirects to Dashboard -->
        <activity
            android:name=".EmbeddedChatActivity"
            android:exported="false" />
        <activity
            android:name=".FragmentChatActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Dashboard: entry point for exploring integration patterns -->
        <activity
            android:name=".DashboardActivity"
            android:exported="false" />

        <!-- Compose-first integration demo -->
        <activity
            android:name=".ComposeChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ResolveKit provided full-screen chat Activity -->
        <activity
            android:name="app.resolvekit.ui.ResolveKitChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Fragment embedding demo -->
        <activity
            android:name=".FragmentHostActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Approval flow demo -->
        <activity
            android:name=".ApprovalDemoActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>
</manifest>
